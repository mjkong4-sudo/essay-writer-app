# OpenAI API Key for essay generation and translation
OPENAI_API_KEY=your_openai_api_key_here

# Auth.js (NextAuth v5) – generate with: openssl rand -base64 32
AUTH_SECRET=your_auth_secret_here
# Production: set to your app URL (e.g. https://yourapp.vercel.app) – Vercel often sets this automatically
# AUTH_URL=https://yourapp.vercel.app

# Optional: only this account can claim legacy data at /admin/migrate-legacy (e.g. admin@test.com)
# LEGACY_MIGRATION_EMAIL=admin@test.com

# Neon Postgres (get both from https://console.neon.tech)
DATABASE_URL=postgresql://user:password@host-pooler.region.aws.neon.tech/dbname?sslmode=require
DIRECT_URL=postgresql://user:password@host.region.aws.neon.tech/dbname?sslmode=require

# Optional: allow cross-origin requests to /api/generate (e.g. from archive viewer). Comma-separated for multiple.
# ESSAY_CORS_ORIGIN=http://localhost:8000,https://your-archive.vercel.app
